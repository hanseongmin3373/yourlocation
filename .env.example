# Kakao Maps SDK (클라이언트)
NEXT_PUBLIC_KAKAO_MAP_KEY=your_kakao_javascript_key_here

# Kakao Local API - 역지오코딩 (서버 전용)
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here

# PostgreSQL (Neon / Vercel Postgres 등)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/yourlocation?sslmode=require

# 세션 JWT 서명 (32자 이상 랜덤 문자열)
AUTH_SECRET=change_this_to_a_long_random_secret_string

# 사이트 URL (Google OAuth 리다이렉트용)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# 관리자 이메일 (쉼표 구분, 최초 관리자·자동 승인)
ADMIN_EMAILS=admin@example.com

# ipinfo.io IP 위치 API — 1차 GeoIP 엔진 (필수, https://ipinfo.io/account/token)
# Plus/Lookup API 토큰 — 미설정 시 ip-api·IP2Location LITE fallback (정확도 저하)
IPINFO_TOKEN=your_ipinfo_token_here

# IP2Location 로컬 BIN (https://www.ip2location.com/file-download)
# 미설정 시 geo-data/*.BIN 자동 탐색 (DB5 이상·IPv6 우선)
IP2LOCATION_BIN_PATH=geo-data/IP2LOCATION-LITE-DB5.BIN

# LITE 자동 다운로드 토큰 (https://lite.ip2location.com/database-download 로그인 후 표시)
IP2LOCATION_DOWNLOAD_TOKEN=your_download_token_here

# mylocation.co.kr IP DB (Cafe24 MSSQL — import 스크립트용, 선택)
# MYLOCATION_MSSQL_URL=Server=host;Database=db;User Id=user;Password=pass;Encrypt=true
# MYLOCATION_MSSQL_TABLE=dbo.IPLocation
# MYLOCATION_MSSQL_QUERY=SELECT IP, Latitude, Longitude, ... FROM dbo.IPLocation

# 경찰관서 DB odcloud API (선택 — 없으면 공공데이터 CSV 직접 다운로드)
# DATA_GO_KR_SERVICE_KEY=your_data_go_kr_key
