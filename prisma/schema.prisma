generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  password        String?
  googleId        String?    @unique
  name            String?
  role            UserRole   @default(USER)
  isApproved      Boolean    @default(false)
  termsAgreedAt   DateTime
  privacyAgreedAt DateTime
  createdAt       DateTime   @default(now())
  queries         QueryLog[]
}

model QueryLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  queryType     String
  queryValue    String
  resultAddress String?
  createdAt     DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

model AnonymousUsage {
  id    String @id @default(cuid())
  ip    String
  date  String
  count Int    @default(0)

  @@unique([ip, date])
}

/// 사용자 GPS+IP 자발 등록 데이터 (mylocation.co.kr 방식)
model IpLocationEntry {
  id             String   @id @default(cuid())
  ip             String   @unique
  ipPrefix24     String
  lat            Float
  lon            Float
  accuracyM      Float
  /// 전체 주소 (역지오코딩)
  address        String
  /// 공개·저장용 적용 주소 (동/읍/면 단위)
  appliedAddress String   @default("")
  dong           String?
  sido           String?
  sigungu        String?
  roadAddress    String?
  isp            String?
  lookupCount    Int      @default(0)
  registerCount  Int      @default(1)
  source         String   @default("gps-register")
  /// 사용자가 도로명 주소를 직접 확인·선택한 경우 (mylocation 방식)
  userVerified   Boolean  @default(false)
  verifiedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([ipPrefix24])
  @@index([isp])
  @@index([updatedAt(sort: Desc)])
}

/// mylocation.co.kr 조회 시도 기록 (MSSQL 없을 때 live backfill용)
model MylocationProbe {
  ip       String   @id
  hit      Boolean
  address  String?
  probedAt DateTime @default(now())

  @@index([probedAt(sort: Desc)])
}
